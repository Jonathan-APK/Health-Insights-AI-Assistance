# copy this to `.env` and fill in real secrets
# local development values are provided for convenience only

# environment flag used by code to enable/disable docs, CORS, etc.
ENV=local

# OpenAI secret for LLM calls
OPENAI_API_KEY=

# redis connection string (Upstash or local)
REDIS_URL=redis://localhost:6379

# comma-separated list of allowed origins for CORS in production
FRONTEND_ORIGINS=["http://localhost:3000"]

# session storage TTL in seconds
SESSION_TTL_SECONDS=1800

# rate limit settings
MAX_MESSAGES_PER_SESSION=50
MAX_UPLOADS_PER_SESSION=3