# Playwright E2E Test Configuration

# Frontend URL
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# Backend API URL (for debugging)
VITE_API_URL=http://localhost:8000

# Test environment
PLAYWRIGHT_TEST_ENV=test

# Timeout settings (ms)
PLAYWRIGHT_TEST_TIMEOUT=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT=30000

# Screenshots and videos
PLAYWRIGHT_SCREENSHOTS=only-on-failure
PLAYWRIGHT_VIDEOS=retain-on-failure

# Browser settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0

# Trace settings
PLAYWRIGHT_TRACES=on-first-retry
